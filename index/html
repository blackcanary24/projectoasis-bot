<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Арт-медитация</title>
    <style>
        :root {
            --bg: #1e1e2e;
            --surface: #2a2a3c;
            --text: #cdd6f4;
            --text-secondary: #a6adc8;
            --accent: #89b4fa;
            --accent-soft: #b4befe;
            --danger: #f38ba8;
            --canvas-bg: #f5f0eb;
            --shadow: 0 2px 8px rgba(0,0,0,0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
            -webkit-user-select: none;
            user-select: none;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--bg);
            color: var(--text);
            height: 100vh;
            height: 100dvh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            overscroll-behavior: none;
            -webkit-overflow-scrolling: none;
        }

        /* === HEADER === */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            background: var(--surface);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            flex-shrink: 0;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-left h1 {
            font-size: 16px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: -0.3px;
        }

        .header-left span {
            font-size: 12px;
            color: var(--text-secondary);
        }

        .close-btn {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.05);
            color: var(--text-secondary);
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .close-btn:hover {
            background: rgba(255,255,255,0.1);
        }

        /* === CANVAS AREA === */
        .canvas-container {
            flex: 1;
            position: relative;
            background: var(--canvas-bg);
            margin: 0;
            cursor: crosshair;
            overflow: hidden;
            border-radius: 0;
        }

        canvas {
            display: block;
            width: 100%;
            height: 100%;
            touch-action: none;
        }

        /* === TIMER === */
        .timer-panel {
            position: absolute;
            top: 12px;
            right: 12px;
            background: var(--surface);
            border-radius: 12px;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: var(--shadow);
            z-index: 10;
            transition: opacity 0.3s;
        }

        .timer-panel.off .timer-display {
            opacity: 0.4;
        }

        .timer-display {
            font-size: 20px;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--accent);
            min-width: 48px;
            text-align: center;
            transition: color 0.3s, opacity 0.3s;
        }

        .timer-display.warning {
            color: #fab387;
            animation: pulse 1.5s infinite;
        }

        .timer-display.timeout {
            color: var(--danger);
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .timer-toggle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: none;
            background: rgba(255,255,255,0.08);
            color: var(--text);
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .timer-toggle:hover {
            background: rgba(255,255,255,0.15);
        }

        .timer-toggle.active {
            background: var(--accent);
            color: var(--bg);
        }

        .timer-presets {
            display: flex;
            gap: 4px;
        }

        .timer-preset {
            font-size: 10px;
            padding: 4px 8px;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.15);
            background: transparent;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.2s;
        }

        .timer-preset:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .timer-preset.active-preset {
            background: var(--accent);
            border-color: var(--accent);
            color: var(--bg);
            font-weight: 600;
        }

        /* === TOAST (задания) === */
        .toast {
            position: absolute;
            bottom: 20px;
            left: 20px;
            right: 20px;
            background: var(--surface);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 14px;
            padding: 14px 18px;
            box-shadow: var(--shadow);
            z-index: 20;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.4s ease, transform 0.4s ease;
            pointer-events: none;
            text-align: center;
            font-size: 14px;
            color: var(--accent-soft);
            line-height: 1.5;
        }

        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-icon {
            font-size: 20px;
            display: block;
            margin-bottom: 4px;
        }

        /* === BOTTOM TOOLBAR === */
        .toolbar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 12px 10px;
            background: var(--surface);
            border-top: 1px solid rgba(255,255,255,0.05);
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        .tool-group {
            display: flex;
            gap: 4px;
            padding: 0 6px;
            border-right: 1px solid rgba(255,255,255,0.08);
        }

        .tool-group:last-child {
            border-right: none;
        }

        .tool-btn {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            border: 1.5px solid transparent;
            background: rgba(255,255,255,0.04);
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s;
            position: relative;
        }

        .tool-btn:hover {
            background: rgba(255,255,255,0.1);
        }

        .tool-btn:active {
            transform: scale(0.92);
        }

        .tool-btn.active {
            border-color: var(--accent);
            background: rgba(137,180,250,0.12);
            color: var(--accent);
        }

        .color-btn {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid transparent;
            cursor: pointer;
            transition: all 0.15s;
            flex-shrink: 0;
        }

        .color-btn:hover {
            transform: scale(1.15);
        }

        .color-btn.active-color {
            border-color: var(--text);
            transform: scale(1.1);
        }

        .sound-toggle {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            border: none;
            background: rgba(255,255,255,0.04);
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s;
        }

        .sound-toggle.muted {
            color: var(--danger);
            opacity: 0.6;
        }
    </style>
</head>
<body>
    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <h1>🎨 Арт-медитация</h1>
            <span>Рисуй • Дыши • Отпускай</span>
        </div>
        <button class="close-btn" id="closeBtn" title="Закрыть">✕</button>
    </div>

    <!-- CANVAS -->
    <div class="canvas-container" id="canvasContainer">
        <canvas id="drawCanvas"></canvas>

        <!-- TIMER -->
        <div class="timer-panel" id="timerPanel">
            <div class="timer-display" id="timerDisplay">03:00</div>
            <div class="timer-presets">
                <button class="timer-preset active-preset" data-seconds="180">3м</button>
                <button class="timer-preset" data-seconds="300">5м</button>
                <button class="timer-preset" data-seconds="600">10м</button>
            </div>
            <button class="timer-toggle" id="timerToggle" title="Вкл/Выкл таймер">⏯</button>
        </div>

        <!-- TOAST -->
        <div class="toast" id="toast">
            <span class="toast-icon">💭</span>
            <span id="toastText"></span>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="tool-group">
            <button class="tool-btn active" id="penTool" title="Карандаш">✏️</button>
            <button class="tool-btn" id="eraserTool" title="Ластик">🧹</button>
        </div>
        <div class="tool-group" id="colorGroup">
            <button class="color-btn active-color" data-color="#4A4A4A" style="background:#4A4A4A;" title="Графит"></button>
            <button class="color-btn" data-color="#6B705C" style="background:#6B705C;" title="Шалфей"></button>
            <button class="color-btn" data-color="#A5A58D" style="background:#A5A58D;" title="Сухая трава"></button>
            <button class="color-btn" data-color="#DDB892" style="background:#DDB892;" title="Песок"></button>
            <button class="color-btn" data-color="#B5838D" style="background:#B5838D;" title="Пыльная роза"></button>
        </div>
        <div class="tool-group">
            <button class="tool-btn" id="clearBtn" title="Очистить">🗑</button>
        </div>
        <div class="tool-group">
            <button class="sound-toggle" id="soundToggle" title="Звук">🔊</button>
        </div>
    </div>

    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
        // ==================== TELEGRAM INIT ====================
        const tg = window.Telegram?.WebApp;
        if (tg) {
            tg.ready();
            tg.expand();
            // Установка цвета фона
            tg.setHeaderColor('#1e1e2e');
            tg.setBackgroundColor('#1e1e2e');
        }

        // ==================== DOM ELEMENTS ====================
        const canvas = document.getElementById('drawCanvas');
        const ctx = canvas.getContext('2d');
        const container = document.getElementById('canvasContainer');
        const timerDisplay = document.getElementById('timerDisplay');
        const timerToggle = document.getElementById('timerToggle');
        const timerPanel = document.getElementById('timerPanel');
        const toast = document.getElementById('toast');
        const toastText = document.getElementById('toastText');
        const penTool = document.getElementById('penTool');
        const eraserTool = document.getElementById('eraserTool');
        const clearBtn = document.getElementById('clearBtn');
        const soundToggle = document.getElementById('soundToggle');
        const closeBtn = document.getElementById('closeBtn');
        const colorBtns = document.querySelectorAll('.color-btn');
        const timerPresets = document.querySelectorAll('.timer-preset');

        // ==================== STATE ====================
        let isDrawing = false;
        let isEraser = false;
        let currentColor = '#4A4A4A';
        let penSize = 3;
        let eraserSize = 25;
        let soundEnabled = true;
        let timerActive = true;
        let timerSeconds = 180;
        let timerInterval = null;
        let taskInterval = null;
        let toastTimeout = null;

        // Задания
        const tasks = [
            'Нарисуй тишину',
            'Нарисуй свой страх в виде линии и преврати его в цветок',
            'Не отрывая руки, нарисуй путь своей мечты',
            'Заполни точками всю свободную область',
            'Изобрази звук, который ты сейчас слышишь',
            'Нарисуй, как выглядит спокойствие',
            'Проведи линию своего дыхания: вдох — вверх, выдох — вниз',
            'Нарисуй что-то, не глядя на холст',
            'Преврати каракули в птицу',
            'Нарисуй круг и заполни его тем, что внутри тебя сейчас'
        ];

        // ==================== CANVAS SETUP ====================
        function resizeCanvas() {
            const rect = container.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            const width = rect.width;
            const height = rect.height;

            // Сохраняем текущий рисунок
            const tempCanvas = document.createElement('canvas');
            const tempCtx = tempCanvas.getContext('2d');
            tempCanvas.width = canvas.width;
            tempCanvas.height = canvas.height;
            tempCtx.drawImage(canvas, 0, 0);

            canvas.width = width * dpr;
            canvas.height = height * dpr;
            canvas.style.width = width + 'px';
            canvas.style.height = height + 'px';
            ctx.scale(dpr, dpr);

            // Восстанавливаем рисунок
            ctx.drawImage(tempCanvas, 0, 0, width, height);

            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.strokeStyle = isEraser ? '#f5f0eb' : currentColor;
            ctx.lineWidth = isEraser ? eraserSize : penSize;
        }

        function initCanvas() {
            resizeCanvas();
            ctx.fillStyle = '#f5f0eb';
            ctx.fillRect(0, 0, canvas.width / (window.devicePixelRatio || 1), canvas.height / (window.devicePixelRatio || 1));
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.strokeStyle = currentColor;
            ctx.lineWidth = penSize;
        }

        window.addEventListener('resize', resizeCanvas);
        initCanvas();

        // ==================== DRAWING ====================
        function getPos(e) {
            const rect = canvas.getBoundingClientRect();
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            return {
                x: clientX - rect.left,
                y: clientY - rect.top
            };
        }

        function startDraw(e) {
            e.preventDefault();
            isDrawing = true;
            const pos = getPos(e);
            ctx.beginPath();
            ctx.moveTo(pos.x, pos.y);

            if (soundEnabled) {
                playDrawSound(isEraser ? 'eraser' : 'pen');
            }
        }

        function draw(e) {
            if (!isDrawing) return;
            e.preventDefault();
            const pos = getPos(e);
            ctx.lineTo(pos.x, pos.y);
            ctx.stroke();

            if (soundEnabled) {
                playDrawSound(isEraser ? 'eraser' : 'pen');
            }
        }

        function stopDraw() {
            if (!isDrawing) return;
            isDrawing = false;
            ctx.closePath();
            stopSound();
        }

        // Mouse events
        canvas.addEventListener('mousedown', startDraw);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDraw);
        canvas.addEventListener('mouseleave', stopDraw);

        // Touch events
        canvas.addEventListener('touchstart', startDraw, { passive: false });
        canvas.addEventListener('touchmove', draw, { passive: false });
        canvas.addEventListener('touchend', stopDraw);
        canvas.addEventListener('touchcancel', stopDraw);

        // ==================== WEB AUDIO API (ASMR SOUNDS) ====================
        let audioCtx = null;
        let noiseNode = null;
        let gainNode = null;
        let filterNode = null;

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }

        function playDrawSound(type) {
            if (!soundEnabled) return;
            initAudio();
            stopSound();

            // Создаём шум
            const bufferSize = audioCtx.sampleRate * 0.1;
            const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const data = buffer.getChannelData(0);

            for (let i = 0; i < bufferSize; i++) {
                data[i] = (Math.random() * 2 - 1) * 0.5;
            }

            noiseNode = audioCtx.createBufferSource();
            noiseNode.buffer = buffer;
            noiseNode.loop = true;

            filterNode = audioCtx.createBiquadFilter();

            if (type === 'pen') {
                // Звук карандаша: высокие частоты, тихий
                filterNode.type = 'highpass';
                filterNode.frequency.value = 2000;
                gainNode = audioCtx.createGain();
                gainNode.gain.value = 0.015;
            } else {
                // Звук ластика: низкие частоты, чуть громче
                filterNode.type = 'lowpass';
                filterNode.frequency.value = 400;
                gainNode = audioCtx.createGain();
                gainNode.gain.value = 0.03;
            }

            noiseNode.connect(filterNode);
            filterNode.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            noiseNode.start(0);
        }

        function stopSound() {
            if (noiseNode) {
                try {
                    noiseNode.stop(0);
                } catch (e) { /* уже остановлен */ }
                noiseNode.disconnect();
                noiseNode = null;
            }
            if (gainNode) {
                gainNode.disconnect();
                gainNode = null;
            }
            if (filterNode) {
                filterNode.disconnect();
                filterNode = null;
            }
        }

        // ==================== TIMER ====================
        function updateTimerDisplay() {
            const mins = Math.floor(timerSeconds / 60);
            const secs = timerSeconds % 60;
            timerDisplay.textContent = String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');

            // Цветовые предупреждения
            timerDisplay.classList.remove('warning', 'timeout');
            if (timerActive && timerSeconds <= 30 && timerSeconds > 0) {
                timerDisplay.classList.add('warning');
            } else if (timerActive && timerSeconds <= 0) {
                timerDisplay.classList.add('timeout');
            }
        }

        function startTimer() {
            stopTimer();
            if (!timerActive) return;
            if (timerSeconds <= 0) return;

            timerInterval = setInterval(() => {
                if (timerSeconds > 0) {
                    timerSeconds--;
                    updateTimerDisplay();
                }
                if (timerSeconds <= 0) {
                    updateTimerDisplay();
                    showToast('Время вышло. Ты молодец, что уделил время себе ❤️');
                }
            }, 1000);
        }

        function stopTimer() {
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
        }

        function resetTimer(seconds) {
            timerSeconds = seconds;
            updateTimerDisplay();
            if (timerActive) {
                startTimer();
            }
        }

        function setTimerActive(active) {
            timerActive = active;
            if (active) {
                timerToggle.classList.add('active');
                timerPanel.classList.remove('off');
                if (timerSeconds > 0) {
                    startTimer();
                }
            } else {
                timerToggle.classList.remove('active');
                timerPanel.classList.add('off');
                stopTimer();
                timerDisplay.classList.remove('warning', 'timeout');
            }
        }

        timerToggle.addEventListener('click', () => {
            setTimerActive(!timerActive);
        });

        timerPresets.forEach(btn => {
            btn.addEventListener('click', () => {
                timerPresets.forEach(b => b.classList.remove('active-preset'));
                btn.classList.add('active-preset');
                const seconds = parseInt(btn.dataset.seconds);
                stopTimer();
                resetTimer(seconds);
            });
        });

        // Инициализация таймера
        setTimerActive(true);
        resetTimer(180);

        // ==================== TASKS ====================
        function showToast(text) {
            toastText.textContent = text;
            toast.classList.add('show');

            if (toastTimeout) clearTimeout(toastTimeout);
            toastTimeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 7000);
        }

        function showRandomTask() {
            const task = tasks[Math.floor(Math.random() * tasks.length)];
            showToast(task);
        }

        function startTaskCycle() {
            stopTaskCycle();
            taskInterval = setInterval(() => {
                if (timerActive && timerSeconds > 0) {
                    showRandomTask();
                }
            }, 45000);
        }

        function stopTaskCycle() {
            if (taskInterval) {
                clearInterval(taskInterval);
                taskInterval = null;
            }
        }

        startTaskCycle();

        // ==================== TOOLS ====================
        function setPenMode() {
            isEraser = false;
            ctx.strokeStyle = currentColor;
            ctx.lineWidth = penSize;
            penTool.classList.add('active');
            eraserTool.classList.remove('active');
        }

        function setEraserMode() {
            isEraser = true;
            ctx.strokeStyle = '#f5f0eb';
            ctx.lineWidth = eraserSize;
            eraserTool.classList.add('active');
            penTool.classList.remove('active');
        }

        penTool.addEventListener('click', setPenMode);
        eraserTool.addEventListener('click', setEraserMode);

        colorBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                colorBtns.forEach(b => b.classList.remove('active-color'));
                btn.classList.add('active-color');
                currentColor = btn.dataset.color;
                if (!isEraser) {
                    ctx.strokeStyle = currentColor;
                    ctx.lineWidth = penSize;
                }
                setPenMode();
            });
        });

        clearBtn.addEventListener('click', () => {
            if (confirm('Очистить холст?')) {
                const rect = container.getBoundingClientRect();
                ctx.clearRect(0, 0, rect.width, rect.height);
                ctx.fillStyle = '#f5f0eb';
                ctx.fillRect(0, 0, rect.width, rect.height);
            }
        });

        // ==================== SOUND ====================
        soundToggle.addEventListener('click', () => {
            soundEnabled = !soundEnabled;
            if (!soundEnabled) {
                stopSound();
                soundToggle.classList.add('muted');
                soundToggle.textContent = '🔇';
            } else {
                soundToggle.classList.remove('muted');
                soundToggle.textContent = '🔊';
            }
        });

        // ==================== CLOSE ====================
        closeBtn.addEventListener('click', () => {
            if (tg) {
                tg.close();
            }
        });

        // ==================== PREVENT SCROLL ====================
        document.addEventListener('gesturestart', (e) => e.preventDefault());
        document.addEventListener('gesturechange', (e) => e.preventDefault());
        document.addEventListener('gestureend', (e) => e.preventDefault());

        // Предотвращаем pull-to-refresh на мобильных
        document.body.addEventListener('touchmove', function(e) {
            if (e.target === canvas || canvas.contains(e.target)) {
                e.preventDefault();
            }
        }, { passive: false });

        console.log('🎨 Арт-медитация готова к работе');
        console.log('Таймер: опциональный | Рисование: без блокировки | ASMR-звуки: Web Audio API');
    </script>
</body>
</html>
